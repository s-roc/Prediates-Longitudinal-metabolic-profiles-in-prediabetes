library(lmerTest)
library(lme4)
library(dplyr)
library(broom.mixed)
library(performance)

# Clear environment
rm(list = ls())

# Define output labels
name.file = "Resultados_LMM_Time_12months"
meses = "12months"

# Load dataset
datos <- read.table("Progression_Datos_Work_12meses_Ingles.txt", header = TRUE, sep = "\t", dec = ".", quote = "", check.names = FALSE)

# Remove non-relevant variables
datos <- subset(datos, select = -c(Try_HDL, Sample, Time_between_T1_and_T5_BQ, Anual_Follow_up, mtDNA_CN_Mean, CV, mtDNA_CN_SD, S_AnthropoAge, Delta_Age))

# Ensure 'Time' is treated as a factor with baseline at 0
datos$Time <- factor(datos$Time)
datos$Time <- relevel(datos$Time, ref = "0")

# Identify numeric variables for modeling
variables_numericas <- datos %>%
  select_if(is.numeric) %>%
  colnames()

# Initialize results container
resultados <- list()

# Define model formulas (no stratification by progression groups)
form_mod_adj1 <- "~ Time + Age + Sex + (1 | ID)"
form_mod_adj2 <- "~ Time + Age + Sex + BMI + (1 | ID)"
form_mod_simple <- "~ Time  + (1 | ID)"

# Fit models for each numeric variable
for (var in variables_numericas) {
  
  # Define model structures
  modelos <- list(
    Adj1 = as.formula(paste(var, form_mod_adj1)),
    Adj2 = as.formula(paste(var, form_mod_adj2)),
    Simple = as.formula(paste(var, form_mod_simple))
  )
  
  # Iterate over model specifications
  for (modelo_name in names(modelos)) {
    formula <- modelos[[modelo_name]]
    
    # Fit linear mixed-effects model
    modelo <- lmer(formula, data = datos, na.action = na.exclude)
    
    # Assess model singularity
    singularidad <- if (isSingular(modelo)) "Singular" else "No Singular"
    
    # Extract model summary
    resumen_modelo <- tidy(modelo)
    
    # Compute AIC
    aic_value <- AIC(modelo)
    
    # Annotate results
    resumen_modelo$Variable <- var
    resumen_modelo$Modelo <- modelo_name
    resumen_modelo$AIC <- aic_value
    resumen_modelo$Singularidad <- singularidad
    
    # Store results
    resultados[[paste(var, modelo_name, sep = "_")]] <- resumen_modelo
  }
}

# Combine all results into a single table
tabla_resultados <- bind_rows(resultados)

# Remove non-relevant columns
tabla_resultados <- tabla_resultados %>%
  select(-effect, -group)

# Reorder columns
tabla_resultados <- tabla_resultados %>%
  select(Variable, Modelo, everything())

# Annotate time point
tabla_resultados <- tabla_resultados %>% mutate(Meses = meses)

# Export results table
write.csv(tabla_resultados, file = paste0(name.file, "_resultados_global.csv"), row.names = FALSE)

# MODEL PERFORMANCE (R2 marginal and conditional)
resultados_r2 <- list()

for (var in variables_numericas) {
  modelos <- list(
    Adj1 = as.formula(paste(var, form_mod_adj1)),
    Adj2 = as.formula(paste(var, form_mod_adj2)),
    Simple = as.formula(paste(var, form_mod_simple))
  )
  
  for (modelo_name in names(modelos)) {
    formula <- modelos[[modelo_name]]
    
    modelo <- lmer(formula, data = datos, na.action = na.exclude)
    
    # Compute marginal and conditional R2
    r2_values <- performance::r2(modelo)
    
    resultados_r2[[paste(var, modelo_name, sep = "_")]] <- data.frame(
      Variable = var,
      Modelo = modelo_name,
      R2_Marginal = r2_values$R2_marginal,
      R2_Condicional = r2_values$R2_conditional
    )
  }
}

# Convert list to data frame
r2_df <- bind_rows(resultados_r2)

# Remove duplicated entries
r2_df <- r2_df %>%
  distinct(Variable, Modelo, .keep_all = TRUE)

# Annotate time point
r2_df <- r2_df %>% mutate(Meses = meses)

# Export R2 results
write.csv(r2_df, file = paste0(name.file, "_bondad_ajuste.csv"), row.names = FALSE)
